{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    { "src": "/", "dest": "/index.html" },
    { "src": "/about", "dest": "/about.html" },
    { "src": "/blog", "dest": "/blog.html" },
    { "src": "/contact", "dest": "/contact.html" },
    { "src": "/portfolio", "dest": "/portfolio.html" },
    { "src": "/portfolio-details", "dest": "/portfolio-details.html" },
    { "src": "/services", "dest": "/services.html" },
    { "src": "/article", "dest": "/article.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
