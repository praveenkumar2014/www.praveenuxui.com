{
  "name": "praveenuxui-portfolio",
  "version": "1.0.0",
  "description": "Praveen Kumar K - Senior UX/UI Architect & AI Agentic Design Strategist Portfolio",
  "private": true,
  "scripts": {
    "build": "php build.php",
    "serve": "php -S localhost:8000 router.php",
    "serve:static": "npx serve . -p 3000 --no-clipboard",
    "test": "npm run test:playwright && npm run test:selenium",
    "test:playwright": "npx playwright test",
    "test:selenium": "node tests/selenium.test.js",
    "test:playwright:ui": "npx playwright test --ui",
    "test:playwright:report": "npx playwright show-report",
    "predeploy": "php build.php",
    "deploy": "vercel --prod",
    "deploy:preview": "vercel",
    "ci": "npm run build && npm run test"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "selenium-webdriver": "^4.43.0",
    "serve": "^14.2.3"
  },
  "dependencies": {
    "tech-stack-icons": "^3.7.1"
  },
  "main": "playwright.config.js",
  "directories": {
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/praveenkumar2014/pranuuxui.com.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/praveenkumar2014/pranuuxui.com/issues"
  },
  "homepage": "https://github.com/praveenkumar2014/pranuuxui.com#readme"
}
